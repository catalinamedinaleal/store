rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authorized() {
      return request.auth != null && request.auth.token.email in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com'
      ];
    }
    match /{document=**} {
      allow read, write: if authorized();
    }
  }
}
